generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  plan         Plan       @default(FREE)
  wordsUsed    Int        @default(0)
  periodStart  DateTime   @default(now())
  createdAt    DateTime   @default(now())
  sessions     Session[]
  documents    Document[]
  projects     Project[]
  activities   Activity[]
  apiKeys      ApiKey[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Project {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime   @default(now())
  documents Document[]

  @@index([userId])
}

model Document {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title        String
  kind         String   @default("humanize")
  originalText String
  improvedText String?
  mode         String   @default("Humanize")
  metrics      Json?
  favorite     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([projectId])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  detail    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  prefix     String
  keyHash    String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}
